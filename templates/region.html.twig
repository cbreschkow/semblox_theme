{#
/**
 * @file
 * Default theme implementation for a region.
 *
 * Available variables:
 * - content: The content for this region, typically blocks.
 * - attributes: HTML attributes for the region <div>.
 * - region: The name of the region variable.
 *
 * @see template_preprocess_region()
 */
#}
{#
  Bestimmte Regions werden als Flex-Container gerendert, damit ihre Blöcke
  horizontal angeordnet werden (z. B. Branding + Account-Menü im Header).
#}
{% set flex_regions = ['header', 'primary_menu'] %}

{% set classes = [
  'region',
  'region--' ~ region|clean_class,
  region in flex_regions ? 'd-flex align-items-center flex-wrap gap-3',
] %}

{% if content %}
  <div{{ attributes.addClass(classes) }}>
    {{ content }}
  </div>
{% endif %}
