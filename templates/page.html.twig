{#
/**
 * @file
 * Default theme implementation to display a single page.
 *
 * Available regions (siehe semblox_theme.info.yml):
 * - header
 * - primary_menu
 * - breadcrumb
 * - highlighted
 * - hero
 * - content
 * - sidebar_left
 * - sidebar_right
 * - footer_top
 * - footer_bottom
 *
 * Bootstrap-Grid-Layout:
 * - Header, Hero, Footer in eigenen Containern (Full-Width-Möglichkeit)
 * - Content-Bereich mit row + Spalten je nach Sidebar-Belegung
 *
 * Variables aus preprocess (siehe semblox_theme.theme):
 * - has_sidebar_left: Bool ob Sidebar links Inhalt hat
 * - has_sidebar_right: Bool ob Sidebar rechts Inhalt hat
 * - content_classes: Bootstrap-Klassen für die Content-Spalte
 *
 * @see template_preprocess_page()
 */
#}
<div class="page-wrapper">

  {# Header --------------------------------------------------------------- #}
  {% if page.header %}
    <header class="site-header" role="banner">
      <div class="container py-3">
        {{ page.header }}
      </div>
    </header>
  {% endif %}

  {# Primary Menu --------------------------------------------------------- #}
  {% if page.primary_menu %}
    <nav class="site-primary-menu" role="navigation" aria-label="{{ 'Primary navigation'|t }}">
      <div class="container">
        {{ page.primary_menu }}
      </div>
    </nav>
  {% endif %}

  {# Breadcrumb ----------------------------------------------------------- #}
  {% if page.breadcrumb %}
    <div class="site-breadcrumb">
      <div class="container">
        {{ page.breadcrumb }}
      </div>
    </div>
  {% endif %}

  {# Hero (selten befüllt) ------------------------------------------------ #}
  {% if page.hero %}
    <section class="site-hero">
      <div class="container">
        {{ page.hero }}
      </div>
    </section>
  {% endif %}

  {# Highlighted (Status-Nachrichten, lokale Aktionen, Tabs) -------------- #}
  {% if page.highlighted %}
    <div class="site-highlighted">
      <div class="container">
        {{ page.highlighted }}
      </div>
    </div>
  {% endif %}

  {# Hauptinhalt mit Sidebars -------------------------------------------- #}
  <main id="main-content" class="page-main" role="main">
    <div class="container">
      <div class="row">

        {% if has_sidebar_left %}
          <aside class="{{ sidebar_classes }} site-sidebar site-sidebar--left" role="complementary">
            {{ page.sidebar_left }}
          </aside>
        {% endif %}

        <div class="{{ content_classes }} site-content">
          {{ page.content }}
        </div>

        {% if has_sidebar_right %}
          <aside class="{{ sidebar_classes }} site-sidebar site-sidebar--right" role="complementary">
            {{ page.sidebar_right }}
          </aside>
        {% endif %}

      </div>
    </div>
  </main>

  {# Footer Top ----------------------------------------------------------- #}
  {% if page.footer_top %}
    <div class="site-footer site-footer--top">
      <div class="container">
        {{ page.footer_top }}
      </div>
    </div>
  {% endif %}

  {# Footer Bottom -------------------------------------------------------- #}
  {% if page.footer_bottom %}
    <div class="site-footer site-footer--bottom">
      <div class="container">
        {{ page.footer_bottom }}
      </div>
    </div>
  {% endif %}

</div>
